{
  "info": {
    "name": "Simple LMS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"password123\",\n  \"role\": \"student\"\n}"
            },
            "url": {"raw": "http://localhost:8000/api/auth/register", "host": ["localhost"], "port": "8000", "path": ["api", "auth", "register"]}
          }
        },
        {
          "name": "Login (Sign In)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"password123\"\n}"
            },
            "url": {"raw": "http://localhost:8000/api/auth/sign-in", "host": ["localhost"], "port": "8000", "path": ["api", "auth", "sign-in"]}
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"isi_refresh_token_dari_login\"\n}"
            },
            "url": {"raw": "http://localhost:8000/api/auth/token-refresh", "host": ["localhost"], "port": "8000", "path": ["api", "auth", "token-refresh"]}
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer isi_access_token"}],
            "url": {"raw": "http://localhost:8000/api/auth/me", "host": ["localhost"], "port": "8000", "path": ["api", "auth", "me"]}
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer isi_access_token"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"nama_baru\"\n}"
            },
            "url": {"raw": "http://localhost:8000/api/auth/me", "host": ["localhost"], "port": "8000", "path": ["api", "auth", "me"]}
          }
        }
      ]
    },
    {
      "name": "COURSES",
      "item": [
        {
          "name": "List Courses",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/api/courses?page=1&limit=10", "host": ["localhost"], "port": "8000", "path": ["api", "courses"], "query": [{"key": "page", "value": "1"}, {"key": "limit", "value": "10"}]}
          }
        },
        {
          "name": "Course Detail",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8000/api/courses/1", "host": ["localhost"], "port": "8000", "path": ["api", "courses", "1"]}
          }
        },
        {
          "name": "Create Course (Instructor)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer isi_access_token_instructor"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Belajar Django\",\n  \"description\": \"Course tentang Django Ninja dan REST API\"\n}"
            },
            "url": {"raw": "http://localhost:8000/api/courses", "host": ["localhost"], "port": "8000", "path": ["api", "courses"]}
          }
        },
        {
          "name": "Update Course (Owner)",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer isi_access_token_instructor"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Belajar Django - Updated\",\n  \"description\": \"Deskripsi yang sudah diperbarui\"\n}"
            },
            "url": {"raw": "http://localhost:8000/api/courses/1", "host": ["localhost"], "port": "8000", "path": ["api", "courses", "1"]}
          }
        },
        {
          "name": "Delete Course (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer isi_access_token_admin"}],
            "url": {"raw": "http://localhost:8000/api/courses/1", "host": ["localhost"], "port": "8000", "path": ["api", "courses", "1"]}
          }
        }
      ]
    },
    {
      "name": "ENROLLMENTS",
      "item": [
        {
          "name": "Enroll to Course (Student)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer isi_access_token_student"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_id\": 1\n}"
            },
            "url": {"raw": "http://localhost:8000/api/enrollments", "host": ["localhost"], "port": "8000", "path": ["api", "enrollments"]}
          }
        },
        {
          "name": "My Courses",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer isi_access_token_student"}],
            "url": {"raw": "http://localhost:8000/api/enrollments/my-courses", "host": ["localhost"], "port": "8000", "path": ["api", "enrollments", "my-courses"]}
          }
        },
        {
          "name": "Mark Lesson Complete",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer isi_access_token_student"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lesson_id\": 1\n}"
            },
            "url": {"raw": "http://localhost:8000/api/enrollments/1/progress", "host": ["localhost"], "port": "8000", "path": ["api", "enrollments", "1", "progress"]}
          }
        }
      ]
    }
  ]
}
