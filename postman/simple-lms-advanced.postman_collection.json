{
  "info": {
    "name": "Simple LMS API - Current Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection synchronized with the current Django Ninja backend endpoints."
  },
  "variable": [
    {"key": "base_url", "value": "http://localhost:8000"},
    {"key": "admin_token", "value": ""},
    {"key": "instructor_token", "value": ""},
    {"key": "student_token", "value": ""},
    {"key": "course_id", "value": "1"},
    {"key": "lesson_id", "value": "1"},
    {"key": "enrollment_id", "value": "1"}
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"admin1\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"},
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Register Instructor",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"instructor1\",\n  \"password\": \"password123\",\n  \"role\": \"instructor\"\n}"},
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"password123\",\n  \"role\": \"student\"\n}"},
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"password123\"\n}"},
            "url": "{{base_url}}/api/auth/sign-in"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"refresh\": \"paste_refresh_token_here\"\n}"},
            "url": "{{base_url}}/api/auth/token-refresh"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{student_token}}"}],
            "url": "{{base_url}}/api/auth/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{student_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\n  \"username\": \"student_renamed\"\n}"},
            "url": "{{base_url}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "COURSES",
      "item": [
        {"name": "List Courses", "request": {"method": "GET", "url": "{{base_url}}/api/courses?page=1"}},
        {"name": "List Courses - Search and Ordering", "request": {"method": "GET", "url": "{{base_url}}/api/courses?search=django&ordering=-id&page=1"}},
        {"name": "Popular Courses", "request": {"method": "GET", "url": "{{base_url}}/api/courses/popular"}},
        {"name": "Course Detail", "request": {"method": "GET", "url": "{{base_url}}/api/courses/{{course_id}}"}},
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{instructor_token}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"title\": \"Belajar Django Ninja\",\n  \"description\": \"Course tentang backend API dengan Django Ninja\"\n}"},
            "url": "{{base_url}}/api/courses"
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{instructor_token}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"title\": \"Belajar Django Ninja Updated\"\n}"},
            "url": "{{base_url}}/api/courses/{{course_id}}"
          }
        },
        {"name": "Delete Course", "request": {"method": "DELETE", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}], "url": "{{base_url}}/api/courses/{{course_id}}"}},
        {"name": "Upload Course Image", "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{instructor_token}}"}], "body": {"mode": "formdata", "formdata": [{"key": "file", "type": "file", "src": ""}]}, "url": "{{base_url}}/api/courses/{{course_id}}/upload-image"}},
        {"name": "Visit Course", "request": {"method": "POST", "url": "{{base_url}}/api/courses/{{course_id}}/visit"}}
      ]
    },
    {
      "name": "LESSONS",
      "item": [
        {"name": "List Lessons", "request": {"method": "GET", "url": "{{base_url}}/api/lessons?page=1"}},
        {"name": "List Lessons by Course", "request": {"method": "GET", "url": "{{base_url}}/api/lessons?course_id={{course_id}}&page=1"}},
        {"name": "Lesson Detail", "request": {"method": "GET", "url": "{{base_url}}/api/lessons/{{lesson_id}}"}},
        {
          "name": "Create Lesson",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{instructor_token}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"course_id\": {{course_id}},\n  \"title\": \"Pengenalan Django Ninja\",\n  \"content\": \"Materi pembuka lesson\",\n  \"order\": 1\n}"},
            "url": "{{base_url}}/api/lessons"
          }
        },
        {
          "name": "Update Lesson",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{instructor_token}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"title\": \"Pengenalan Django Ninja Updated\"\n}"},
            "url": "{{base_url}}/api/lessons/{{lesson_id}}"
          }
        },
        {"name": "Delete Lesson", "request": {"method": "DELETE", "header": [{"key": "Authorization", "value": "Bearer {{instructor_token}}"}], "url": "{{base_url}}/api/lessons/{{lesson_id}}"}},
        {"name": "Upload Lesson Attachment", "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{instructor_token}}"}], "body": {"mode": "formdata", "formdata": [{"key": "file", "type": "file", "src": ""}]}, "url": "{{base_url}}/api/lessons/{{lesson_id}}/upload-attachment"}},
        {"name": "Download Lesson Attachment", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{student_token}}"}], "url": "{{base_url}}/api/lessons/{{lesson_id}}/download"}}
      ]
    },
    {
      "name": "ENROLLMENTS AND PROGRESS",
      "item": [
        {
          "name": "Enroll to Course",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{student_token}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"course_id\": {{course_id}}\n}"},
            "url": "{{base_url}}/api/enrollments"
          }
        },
        {"name": "My Courses", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{student_token}}"}], "url": "{{base_url}}/api/enrollments/my-courses"}},
        {
          "name": "Mark Lesson Complete",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{student_token}}"}],
            "body": {"mode": "raw", "raw": "{\n  \"lesson_id\": {{lesson_id}}\n}"},
            "url": "{{base_url}}/api/enrollments/{{enrollment_id}}/progress"
          }
        }
      ]
    },
    {
      "name": "GENERAL",
      "item": [
        {"name": "Hello", "request": {"method": "GET", "url": "{{base_url}}/api/hello"}},
        {"name": "Health Check", "request": {"method": "GET", "url": "{{base_url}}/api/health"}},
        {"name": "My History", "request": {"method": "GET", "url": "{{base_url}}/api/my-history"}},
        {"name": "Trigger Test Task", "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{admin_token}}"}], "url": "{{base_url}}/api/test-task"}}
      ]
    }
  ]
}
